# webhook credentials — copy to  webhooks/config.env  and fill in the providers
# you use. Env vars of the same name override these. Keep this file out of git: it
# holds secret URLs/tokens (anyone with a webhook URL can post to your channel).
# Both slack_send.sh and discord_send.sh auto-source it.

## --- Slack (fill in ONE transport) ---
# Transport A — Incoming Webhook (simplest; posts to one preset channel):
SLACK_WEBHOOK_URL=
# Transport B — Bot token (chat.postMessage; any channel). Needs chat:write and
# the bot invited to the channel. If set, this wins over the webhook.
SLACK_BOT_TOKEN=
SLACK_CHANNEL=          # default channel for bot mode, e.g. #alerts (or a channel id)

## --- Discord ---
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=       # optional: override the name shown on posts
