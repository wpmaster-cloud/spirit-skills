# Email skill credentials — copy to email/config.env and fill in.
#
#   cp skills/email/config.env.example email/config.env
#
# The scripts auto-source email/config.env (unless the vars are already in the
# environment, which wins). Keep the real file out of git: git-ignore
# `email/config.env` in the agent's folder.
#
# Use an APP PASSWORD (with 2FA enabled), not your normal login password.
# See references/providers.md for per-provider steps.

EMAIL_ADDRESS=you@gmail.com
EMAIL_PASSWORD=your-app-password

# Option A: a known provider auto-fills IMAP/SMTP hosts.
#   gmail | outlook | office365 | yahoo | icloud | fastmail | zoho | gmx
EMAIL_PROVIDER=gmail

# Option B: instead of EMAIL_PROVIDER, set hosts explicitly for any IMAP/SMTP server.
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls      # starttls (587) or ssl (465); inferred from port if unset

# Optional display name on outgoing mail.
# EMAIL_FROM_NAME=Your Name
