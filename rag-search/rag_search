#!/usr/bin/env bash
# Semantic recall over this agent's own indexed subtree, via the indexer.
# Uses the server-injected INDEXER_URL + RAG_TOKEN (present only when the indexer
# is deployed); self-disables otherwise. The indexer embeds the query, so no key
# or embedding logic lives here.
#
#   Usage:  rag_search "query text" [k]      (k = number of passages, default 5)
set -euo pipefail

if [[ -z "${INDEXER_URL:-}" || -z "${RAG_TOKEN:-}" ]]; then
  echo "rag_search: indexer not configured (no INDEXER_URL/RAG_TOKEN) — use rg/grep instead" >&2
  exit 1
fi

q="${1:?usage: rag_search QUERY [k]}"
k="${2:-5}"
[[ "$k" =~ ^[0-9]+$ ]] || k=5

jq -nc --arg q "$q" --argjson k "$k" '{query:$q, k:$k}' \
  | curl -sS --max-time 30 -X POST "$INDEXER_URL/search" \
      -H "Authorization: Bearer $RAG_TOKEN" \
      -H "Content-Type: application/json" \
      --data-binary @-
