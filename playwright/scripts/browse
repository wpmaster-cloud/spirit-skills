#!/usr/bin/env bash
# browse — drive the shared browser-go browser AND make the run watchable.
#
# It's a thin wrapper over browser-go's HTTP API that keeps your session+page ids
# in $AGENT_HOME/.browser.json (a dotfile, invisible to the vault index). That one
# file is what lets spirit's UI attach a LIVE screencast of the page — so prefer
# `browse` over raw curl whenever you want a human to watch you work. Reusing one
# persistent session across calls (instead of one-shot /render) is exactly what
# makes the live view possible.
#
# You can hold SEVERAL sessions at once (each an isolated browser context with
# its own cookies): name them with -s. Without -s you get the "default" session.
#
# Usage:
#   browse [-s NAME] goto URL       navigate (opens the session if none is live)
#   browse [-s NAME] click SELECTOR
#   browse [-s NAME] fill SELECTOR VALUE
#   browse [-s NAME] press SELECTOR KEY
#   browse [-s NAME] text [SELECTOR]  inner text (default: body)
#   browse [-s NAME] content        full HTML of the page
#   browse [-s NAME] wait [STATE]   load|domcontentloaded|networkidle (default networkidle)
#   browse [-s NAME] eval EXPR      run JS, return the result
#   browse [-s NAME] shot [full]    PNG of the page to stdout (full=full_page)
#   browse sessions                 list recorded sessions and whether each is live
#   browse url                      print the recorded {name: {session_id,page_id}} map
#   browse [-s NAME] close          end that session and forget it
#   browse close all                end every recorded session
set -euo pipefail

B="${BROWSER_URL:-http://browser-go.spirit-browser.svc.cluster.local}"
H="Authorization: Bearer ${BROWSER_TOKEN:-}"   # ignored by browser-go when it runs open
STATE="${AGENT_HOME:-$PWD}/.browser.json"

NAME=default
if [ "${1:-}" = "-s" ]; then NAME="${2:?session name}"; shift 2; fi

api() { curl -fsS -H "$H" "$@"; }

# read_state prints the {name: {session_id,page_id}} map, normalizing the legacy
# single-session file ({session_id,page_id} at top level → nested under "default").
read_state() {
  jq -c 'if has("sessions") then .sessions
         elif has("session_id") then {default: .}
         else {} end' "$STATE" 2>/dev/null || echo '{}'
}

write_state() {  # write_state MAP-JSON — persist, or remove the file when empty
  if [ "$1" = '{}' ]; then rm -f "$STATE"; else jq -nc --argjson s "$1" '{sessions: $s}' > "$STATE"; fi
}

# ensure_session sets SID/PID to a live session named $NAME, reusing the recorded
# one when it's still alive (browser-go reaps idle sessions after ~10m) and
# creating a fresh one otherwise. New ids are recorded so the UI can find them.
ensure_session() {
  if SID=$(read_state | jq -re --arg n "$NAME" '.[$n].session_id' 2>/dev/null) \
     && PID=$(read_state | jq -re --arg n "$NAME" '.[$n].page_id' 2>/dev/null) \
     && api "$B/sessions/$SID/pages/$PID/act" -d '{"action":"title"}' >/dev/null 2>&1; then
    return
  fi
  local sp
  sp=$(api "$B/sessions" -d '{"width":1280,"height":800}')
  SID=$(jq -r .session_id <<<"$sp")
  PID=$(jq -r .page_id <<<"$sp")
  write_state "$(read_state | jq -c --arg n "$NAME" --arg s "$SID" --arg p "$PID" \
    '. + {($n): {session_id: $s, page_id: $p}}')"
}

act() { api "$B/sessions/$SID/pages/$PID/act" -d "$1"; }

cmd="${1:-}"; shift || true
case "$cmd" in
  goto)    ensure_session; act "$(jq -nc --arg u "${1:?url}" '{action:"goto",url:$u}')" ;;
  click)   ensure_session; act "$(jq -nc --arg s "${1:?selector}" '{action:"click",selector:$s}')" ;;
  fill)    ensure_session; act "$(jq -nc --arg s "${1:?selector}" --arg v "${2-}" '{action:"fill",selector:$s,value:$v}')" ;;
  press)   ensure_session; act "$(jq -nc --arg s "${1:?selector}" --arg k "${2:?key}" '{action:"press",selector:$s,key:$k}')" ;;
  text)    ensure_session; act "$(jq -nc --arg s "${1:-body}" '{action:"text",selector:$s}')" ;;
  content) ensure_session; act '{"action":"content"}' ;;
  wait)    ensure_session; act "$(jq -nc --arg s "${1:-networkidle}" '{action:"wait",state:$s}')" ;;
  eval)    ensure_session; act "$(jq -nc --arg e "${1:?expr}" '{action:"eval",expr:$e}')" ;;
  shot)    ensure_session; [ "${1:-}" = "full" ] && fp=true || fp=false
           api "$B/sessions/$SID/pages/$PID/screenshot?full_page=$fp" ;;
  sessions)
    read_state | jq -r 'to_entries[] | "\(.key)\t\(.value.session_id)"' \
    | while IFS="$(printf '\t')" read -r n sid; do
        if api "$B/sessions/$sid/pages" >/dev/null 2>&1; then st=live; else st=dead; fi
        printf '%s\t%s\n' "$n" "$st"
      done ;;
  url)     read_state ;;
  close)
    if [ "${1:-}" = all ]; then
      read_state | jq -r '.[].session_id' | while read -r sid; do
        api -X DELETE "$B/sessions/$sid" >/dev/null 2>&1 || true
      done
      rm -f "$STATE"
    else
      # Always drop the entry, even if the handle is corrupt or the DELETE fails.
      if SID=$(read_state | jq -re --arg n "$NAME" '.[$n].session_id' 2>/dev/null); then
        api -X DELETE "$B/sessions/$SID" >/dev/null 2>&1 || true
      fi
      write_state "$(read_state | jq -c --arg n "$NAME" 'del(.[$n])')"
    fi ;;
  *)
    sed -n '2,27p' "$0" | sed 's/^# \{0,1\}//'  # print the usage header
    exit 2 ;;
esac
