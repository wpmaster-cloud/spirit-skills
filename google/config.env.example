# Google (Gmail + Drive) credentials for the google skill.
# Prefer real env vars (the pod Secret / the shell that launches agent.sh).
# If you use this file instead, copy it to <workspace>/google/config.env and
# make sure that path is git-ignored — it holds a long-lived refresh token.
# Env vars win over this file when both are set.
#
# One OAuth client + one refresh token carries Gmail, Drive AND Calendar when you
# mint the token with all the scopes. See references/google-api.md for setup.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
