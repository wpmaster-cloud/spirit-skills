# Vercel skill credentials — copy to vercel/config.env and fill in.
#
#   cp skills/vercel/config.env.example vercel/config.env
#
# The script sources this file only when VERCEL_TOKEN is not already in the
# environment (env always wins). Keep the real file out of git: git-ignore
# `vercel/config.env` in the agent's folder. Never echo the token.

# Vercel access token (REQUIRED) — create at https://vercel.com/account/tokens
# The CLI reads VERCEL_TOKEN natively; the skill never passes it as --token.
VERCEL_TOKEN=

# Team slug (OPTIONAL) — set only if the token belongs to a team rather than a
# personal account; it's added as --scope to every call. Find it in the team's
# Vercel URL / settings.
VERCEL_TEAM=

# Pin to an existing project (OPTIONAL) — set BOTH or NEITHER. When both are
# present the CLI skips the .vercel/ link directory entirely. Get them from the
# project's Settings page or `.vercel/project.json` after a first deploy.
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Where to install Node + the Vercel CLI (OPTIONAL) — default ~/.local. Point at
# a persistent, committable path so the toolchain survives pod restarts:
#   RUNTIME_PREFIX=/work/tools
#   VERCEL_NPM_PREFIX=/work/tools
