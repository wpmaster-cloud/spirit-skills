# Web-search skill credentials — copy to search/config.env and fill in what you
# have. One provider is enough; the script auto-picks the best configured one
# (tavily > brave > serper > searxng > keyless ddg).
#
#   cp skills/web-search/config.env.example search/config.env
#
# The script sources search/config.env only when none of these are already in
# the environment (env always wins). Keep the real file out of git: git-ignore
# `search/config.env` in the agent's folder. Never echo the keys.

# Tavily — https://app.tavily.com — built for agents, returns a direct answer
# alongside results. Free tier: ~1,000 credits/month.
TAVILY_API_KEY=

# Brave Search API — https://api-dashboard.search.brave.com — independent
# index, clean JSON. Free tier: ~2,000 queries/month (1 req/s).
BRAVE_API_KEY=

# Serper — https://serper.dev — real Google results. Free trial credits,
# then pay-as-you-go.
SERPER_API_KEY=

# Self-hosted SearXNG instance, e.g. http://10.0.0.5:8888 — keyless and
# private; its settings.yml must enable the json format.
SEARXNG_URL=

# Force a provider instead of auto-pick: tavily | brave | serper | searxng | ddg
SEARCH_PROVIDER=
