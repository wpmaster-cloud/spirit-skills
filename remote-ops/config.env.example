# remote-ops defaults — copy to  remote-ops/config.env  and fill in.
# Env vars of the same name override these. Keep this file (and any keys) out of
# git: it can hold a path to a private key. The scripts auto-source it.

SSH_HOST=
SSH_USER=
SSH_PORT=22

# Path to the private key. Keep it inside the agent's own folder — that is the only
# place the jail lets you read from ($HOME is the server's home, not yours). chmod 600.
SSH_KEY=

# Trust policy for unknown host keys:
#   accept-new  trust-on-first-use, remember it          (default, good for agents)
#   yes         strict — only hosts already in known_hosts
#   no          accept anything, never record            (insecure; avoid)
SSH_STRICT=accept-new

# Where host keys are remembered (must be writable → keep it in your own folder;
# defaults to .ssh/known_hosts there):
SSH_KNOWN_HOSTS=

# Seconds before a stalled connect attempt gives up.
SSH_CONNECT_TIMEOUT=15
