# Telegram skill credentials — copy to telegram/config.env and fill in.
#
#   cp skills/telegram/config.env.example telegram/config.env
#
# The scripts source telegram/config.env automatically (unless the vars are
# already set in the environment, which takes precedence). Keep the real file out
# of git: git-ignore `telegram/config.env` in the agent's folder.
#
# Get the token from @BotFather. Get the chat id by running tg_setup.sh after
# messaging your bot once.

TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=
